RUST_LOG=wiggler=info,info
WIGGLER_ASSETS=btc,eth,sol,xrp,doge
WIGGLER_TRADABLE_ASSETS=btc,eth,sol,xrp,doge
WIGGLER_RUNTIME_BUNDLE_DIR=runtime/wiggler-prod-v1
WIGGLER_LIVE_TRADING=false
WIGGLER_LIVE_ORDER_TYPE=fak
WIGGLER_MIN_ORDER_USDC=1
WIGGLER_MAX_ORDER_USDC=25
WIGGLER_EVALUATION_INTERVAL_MS=1000
WIGGLER_LOG_EVALUATIONS=false
WIGGLER_PRICE_STALE_AFTER_MS=20000
WIGGLER_ORDERBOOK_STALE_AFTER_MS=10000
WIGGLER_MIN_ABS_D_BPS=0.01

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob-v2.polymarket.com
POLYMARKET_CLOB_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_RTDS_WS_URL=wss://ws-live-data.polymarket.com

# Required only when WIGGLER_LIVE_TRADING=true.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_SIGNATURE_TYPE=eoa
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_API_NONCE=

# Optional. Live and shadow decisions use this when configured.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
